# Application
APP_NAME="Agent Backend"
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (IMPORTANT: Change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for API keys at rest (32 bytes)
ENCRYPTION_KEY=32-byte-encryption-key-here!!

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-media
S3_PUBLIC_URL=http://localhost:9000/agent-media
