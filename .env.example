# Application
APP_NAME="Agent Backend"
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (IMPORTANT: Change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption key for API keys at rest (32 bytes)
ENCRYPTION_KEY=32-byte-encryption-key-here!!

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-media
S3_PUBLIC_URL=http://localhost:9000/agent-media

# AI Providers (alternative to database config)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_IMAGE_MODEL=image-01

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Alibaba Cloud (SMS & Email)
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxx
ALIYUN_EMAIL_DOMAIN=your_domain
ALIYUN_EMAIL_ACCOUNT=notify@example.com
ALIYUN_EMAIL_ACCOUNT_NAME=Agent
